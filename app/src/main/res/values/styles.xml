<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Type scale -->
    <style name="Text">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="Text.Display">
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Title">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Subtitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/on_surface_secondary</item>
    </style>

    <style name="Text.Body">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Text.Caption">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/on_surface_secondary</item>
    </style>

    <style name="Text.Stat">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="Text.StatLabel">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_secondary</item>
    </style>

    <!-- Buttons -->
    <style name="Button">
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:paddingLeft">@dimen/spacing_l</item>
        <item name="android:paddingRight">@dimen/spacing_l</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Button.Primary">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Button.Secondary">
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="Button.Destructive">
        <item name="android:background">@drawable/btn_destructive</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Button.Success">
        <item name="android:background">@drawable/btn_success</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Button.Info">
        <item name="android:background">@drawable/btn_info</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Text-only button for low-emphasis actions like logout -->
    <style name="Button.Text">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/on_surface_secondary</item>
    </style>

    <!-- Form fields -->
    <style name="FormField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="android:paddingLeft">@dimen/spacing_m</item>
        <item name="android:paddingRight">@dimen/spacing_m</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textColorHint">@color/on_surface_secondary</item>
        <item name="android:background">@drawable/field_background</item>
    </style>

</resources>
