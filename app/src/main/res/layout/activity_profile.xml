<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    tools:context=".ProfileActivity">

    <android.support.design.widget.BottomNavigationView
        android:id="@+id/navigation_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:itemBackground="@color/colorPrimary"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:menu="@menu/navigation_main" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/spacing_m">

            <Button
                android:id="@+id/logout_button"
                style="@style/Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:minHeight="@dimen/touch_target_min"
                android:text="Log out" />

            <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:contentDescription="Profile photo"
                android:src="@drawable/bibi_sport_israel" />

            <TextView
                android:id="@+id/tvName"
                style="@style/Text.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m"
                android:gravity="center"
                android:text="benjamin" />

            <TextView
                android:id="@+id/tvDescription"
                style="@style/Text.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center"
                android:text="" />

            <LinearLayout
                android:id="@+id/ButtonLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnFriendRequest"
                    style="@style/Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Friend request" />

                <Button
                    android:id="@+id/btnMessage"
                    style="@style/Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="@dimen/spacing_s"
                    android:text="Invite for a game" />
            </LinearLayout>

            <!-- Stats card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="@dimen/spacing_m">

                <LinearLayout
                    android:id="@+id/linearLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/friends_num"
                            style="@style/Text.Stat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3260" />

                        <TextView
                            android:id="@+id/friends"
                            style="@style/Text.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Friends" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/chats_num"
                            style="@style/Text.Stat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30M" />

                        <TextView
                            android:id="@+id/chats"
                            style="@style/Text.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chats" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/line"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:layout_marginBottom="@dimen/spacing_m"
                    android:background="@color/divider" />

                <LinearLayout
                    android:id="@+id/linearLayout_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/favorite_court_num"
                            style="@style/Text.Stat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="130" />

                        <TextView
                            android:id="@+id/favorite_court"
                            style="@style/Text.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Favorite courts" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/history_games_num"
                            style="@style/Text.Stat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12" />

                        <TextView
                            android:id="@+id/history_games"
                            style="@style/Text.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Games played" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/line_2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:layout_marginBottom="@dimen/spacing_m"
                    android:background="@color/divider" />

                <LinearLayout
                    android:id="@+id/linearLayout_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/age_num"
                            style="@style/Text.Stat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="70" />

                        <TextView
                            android:id="@+id/age"
                            style="@style/Text.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Age" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/groups_num"
                            style="@style/Text.Stat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5" />

                        <TextView
                            android:id="@+id/groups"
                            style="@style/Text.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Groups" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
