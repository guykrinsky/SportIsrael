<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="@dimen/spacing_s"
    android:paddingBottom="@dimen/spacing_s">

    <TextView
        android:id="@+id/request_user_name"
        style="@style/Text.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="1"
        android:ellipsize="end" />

    <Button
        android:id="@+id/request_decline"
        style="@style/Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        android:textSize="14sp"
        android:text="@string/groups_decline" />

    <Button
        android:id="@+id/request_approve"
        style="@style/Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/spacing_s"
        android:minHeight="40dp"
        android:paddingLeft="@dimen/spacing_m"
        android:paddingRight="@dimen/spacing_m"
        android:textSize="14sp"
        android:text="@string/groups_approve" />
</LinearLayout>
